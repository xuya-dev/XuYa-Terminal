{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/main/schema.json",
  "productName": "XuYa Terminal",
  "version": "0.1.1",
  "identifier": "com.xuya.terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "XuYa Terminal",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ]
  }
}
