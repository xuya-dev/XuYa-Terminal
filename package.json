{
  "name": "xuya-terminal",
  "private": true,
  "version": "1.0.3",
  "license": "Apache-2.0",
  "description": "XuYa Terminal — AI-native terminal emulator",
  "homepage": "https://github.com/xuya-dev/XuYa-Terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/xuya-dev/XuYa-Terminal.git"
  },
  "keywords": [
    "terminal",
    "ai",
    "agent",
    "claude",
    "codex",
    "tauri"
  ],
  "type": "module",
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "dev:inspect": "INSPECT=true vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "version:set": "node scripts/set-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "analyze:bundle": "ANALYZE=true vite build",
    "analyze:eager": "node scripts/eager-graph.mjs src/main.tsx && node scripts/eager-graph.mjs src/settings/main.tsx",
    "size": "size-limit",
    "knip": "knip"
  },
